PORT=5000
NODE_ENV=development

# MongoDB (use standard mongodb:// URI on Windows if mongodb+srv fails)
MONGODB_URI=mongodb://localhost:27017/devlog-ai

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Gemini (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# LinkedIn OAuth (create app at https://www.linkedin.com/developers/)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/linkedin/callback

# Frontend URL (for OAuth redirects)
CLIENT_URL=http://localhost:5173
